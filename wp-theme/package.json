{
  "name": "bella-vip-theme",
  "version": "1.0.0",
  "description": "Tailwind Build System para Tema WP",
  "scripts": {
    "build": "npx @tailwindcss/cli -i ./src/style.css -o ./bellavip/assets/css/output.css",
    "watch": "npx @tailwindcss/cli -i ./src/style.css -o ./bellavip/assets/css/output.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^4.0.0",
    "@tailwindcss/cli": "^4.0.0"
  }
}
